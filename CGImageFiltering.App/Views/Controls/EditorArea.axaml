<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CGImageFiltering.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:MainWindowViewModel"
             x:Class="CGImageFiltering.App.Views.Controls.EditorArea">
    
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                
                <Button Content="Apply Filter"
                    Command="{Binding ApplyBrigthnessFilterCommand}"/>
                <Button Grid.Row="1" Content="Invert Image" 
                        Command="{Binding ApplyInversionFilterCommand}"/>
                <Button Grid.Row="2" Content="Gamma Correction" 
                        Command="{Binding ApplyGammaCorrectionFilterCommand}"/>
                <Button Grid.Row="3" Content="Contrast Enhancement" 
                        Command="{Binding ApplyContrastEnhancementFilterCommand}"/>
            </Grid>
</UserControl>
