<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CGImageFiltering.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:EditorViewModel"
             x:Class="CGImageFiltering.App.Views.Controls.EditorArea">
    
            <Grid MinWidth="300">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition MinHeight="300" 
                                   Height="Auto">
                    </RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                
                <StackPanel 
                    Orientation="Horizontal"
                            Spacing="8">
                    <RadioButton Content="Add"
                                 GroupName="EditorModes"
                                 IsChecked="{Binding IsAddMode}"
                                 Command="{Binding SetAddModeCommand}" />

                    <RadioButton Content="Drag"
                                 GroupName="EditorModes"
                                 IsChecked="{Binding IsDragMode}"
                                 Command="{Binding SetDragModeCommand}" />

                    <RadioButton Content="Remove"
                                 GroupName="EditorModes"
                                 IsChecked="{Binding IsRemoveMode}"
                                 Command="{Binding SetRemoveModeCommand}" />
                </StackPanel>
                
                <Border Grid.Row="1"
                        Padding="10"
                        BorderThickness="1"
                        BorderBrush="#D0D7DE"
                        Background="#F8F9FB"
                        BoxShadow="0 4 14 0 #22000000">
                    <Canvas Width="256"
                            Height="256"
                            Background="White"
                            PointerPressed="OnPointerPressed"
                            PointerMoved="OnPointerMoved"
                            PointerReleased="OnPointerReleased"
                            >
                        <Polyline Points="{Binding PolylinePoints}"
                                  Stroke="Black"
                                  StrokeThickness="1"/>

                        <ItemsControl Width="256"
                                      Height="256"
                                      Canvas.Left="0"
                                      Canvas.Top="0"
                                      ItemsSource="{Binding GraphPoints}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12"
                                             Height="12"
                                             Fill="White"
                                             Stroke="Blue"
                                             StrokeThickness="2">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform X="{Binding EllipseX}"
                                                                Y="{Binding EllipseY}" />
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Border>
                
                <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0 10 0 0">
                    <Button Content="New"
                            Command="{Binding NewGraphCommand}" />

                    <Button Content="Edit"
                            Command="{Binding EditGraphCommand}" />

                    <Button Content="Save"
                            Command="{Binding SaveGraphCommand}" />
                    
                    <TextBlock Text="Filter name:"
                               VerticalAlignment="Center"
                               Margin="12 0 0 0" />

                    <TextBox Width="180"
                             Watermark="Enter filter name"
                             Text="{Binding FilterName}"
                             IsEnabled="{Binding IsFilterNameEditable}" />
                </StackPanel>
                
                <Grid Grid.Row="3"
                      Margin="0 10 0 0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox HorizontalAlignment="Stretch"
                             ItemsSource="{Binding Filters}"
                             CornerRadius="8"
                             SelectedItem="{Binding SelectedFilter}"
                             >
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" MinHeight="30">
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Margin="30 0 0 0"
                                               Text="{Binding ParameterName}"
                                               VerticalAlignment="Center"/>
                                    <NumericUpDown FontSize="12"
                                                   Value="{Binding Parameter, Mode=TwoWay}"
                                                   Minimum="{Binding MinParameterValue}"
                                                   Maximum="{Binding MaxParameterValue}"
                                                   Increment="{Binding ParameterIncrement}"
                                                   IsVisible="{Binding HasParameter}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </ScrollViewer>
                </Grid>
            </Grid>
</UserControl>
